// 규제 보고 전용 서비스 (regulatory-report-service)
@Service
public class RegulatoryReportingService {

    // ❶ 체결 즉시 KOSCOM 거래정보시스템 보고
    @KafkaListener(topics = "execution-events")
    @Transactional
    public void reportToKoscom(ExecutionEvent event) {
        KoscomTradeReport report = KoscomTradeReport.builder()
            .execId(event.getExecId())
            .symbol(event.getSymbol())
            .executionPrice(event.getExecutionPrice())
            .executionQty(event.getExecutionQuantity())
            .buyMemberId(event.getBuyMemberId())
            .sellMemberId(event.getSellMemberId())
            .tradeTime(event.getExecTime())
            .reportTime(Instant.now())
            .build();

        koscomApiClient.submitTradeReport(report); // KOSCOM API
        auditService.record("REGULATORY_REPORT_KOSCOM", report);
    }

    // ❷ 대량 보유(5%) 자동 감지 및 보고
    @Transactional
    public void checkLargeHolding(String investorCiHash, String symbol) {
        BigDecimal shares  = positionService.getPosition(investorCiHash, symbol);
        BigDecimal total   = instrumentService.getTotalShares(symbol);
        BigDecimal holding = shares.divide(total, 4, RoundingMode.HALF_UP);

        if (holding.compareTo(new BigDecimal("0.05")) >= 0) {
            LargeHoldingReport report = LargeHoldingReport.builder()
                .investorCiHash(investorCiHash)
                .symbol(symbol)
                .holdingRatio(holding)
                .reportDeadline(LocalDate.now().plusDays(5)) // 5일 이내
                .build();

            dartApiClient.submitLargeHolding(report); // DART 전자공시
            auditService.record("LARGE_HOLDING_REPORT", report);
        }
    }

    // ❸ FIX ExecutionReport (MsgType=8) 생성
    public String buildFIXExecutionReport(ExecutionResult exec) {
        return new FixMessageBuilder()
            .field(8,  "FIX.5.0")           // BeginString
            .field(35, "8")                  // MsgType = ExecutionReport
            .field(17, exec.getExecId())     // ExecID
            .field(37, exec.getOrderId())    // OrderID
            .field(11, exec.getClOrdId())    // ClOrdID
            .field(150, "2")                 // ExecType = 2 (Trade)
            .field(39, "2")                  // OrdStatus = 2 (Filled)
            .field(55, exec.getSymbol())     // Symbol
            .field(54, exec.getSide())       // Side
            .field(32, exec.getExecQty())    // LastQty
            .field(31, exec.getExecPx())     // LastPx
            .field(14, exec.getCumQty())     // CumQty
            .field(151, exec.getLeavesQty()) // LeavesQty
            .field(60, exec.getTransactTime()) // TransactTime (UTC)
            .build();
    }
}
