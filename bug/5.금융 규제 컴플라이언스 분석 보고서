```java
// 계좌 개설 시 KYC 체크
@Service
public class KycService {

    private final ExternalKycProvider kycProvider;  // 금융결제원 KYC API
    private final SanctionListService sanctionList; // OFAC/금융위 제재 명단

    public KycResult verify(String ci, String name, String nationality) {
        // ❶ 제재 명단 확인 (OFAC, UN, 금융위)
        if (sanctionList.isMatch(name, nationality)) {
            return KycResult.REJECTED_SANCTIONS;
        }

        // ❷ PEP(정치적 노출 인물) 확인
        if (pepDatabase.isMatch(ci)) {
            return KycResult.ENHANCED_DUE_DILIGENCE;  // 강화 실사 필요
        }

        // ❸ 금융결제원 실명 확인
        boolean verified = kycProvider.verifyIdentity(ci, name);
        return verified ? KycResult.PASSED : KycResult.REJECTED;
    }
}

// 주문 처리 시 AML 실시간 체크
@Component
public class AmlChecker {

    public void checkOrder(String investorCi, BigDecimal amount,
                            String symbol, String side) {
        // ❶ 일중 거래 누적 금액 (CTR: Currency Transaction Report)
        // 2천만원 이상 현금 거래 → FIU 자동 보고
        BigDecimal dailyVolume = getDailyTradingVolume(investorCi);
        if (dailyVolume.compareTo(new BigDecimal("20000000")) >= 0) {
            fiuReportService.submitCTR(investorCi, dailyVolume);
        }

        // ❷ 비정상 패턴 감지 (STR: Suspicious Transaction Report)
        if (isAbnormalPattern(investorCi, amount, symbol)) {
            fiuReportService.submitSTR(investorCi, amount, "ABNORMAL_PATTERN");
            auditService.record("AML_SUSPICIOUS", investorCi, amount.toString());
        }

        // ❸ 제재국 IP 차단 확인 (계좌의 마지막 접속 국가)
        String accessCountry = sessionService.getLastCountry(investorCi);
        if (sanctionList.isSanctionedCountry(accessCountry)) {
            throw new SanctionedCountryException("제재 대상 국가로부터의 접속");
        }
    }
}
```

