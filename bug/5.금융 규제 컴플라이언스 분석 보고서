### 🟠 MAJOR-03. Brute Force / 비정상 접근 탐지 미흡

**현재 구현**:
```java
// IP 기반 Rate Limiter만 존재
// → 동일 IP에서 다른 계정으로 무차별 로그인 시도 시 감지 안 됨
// → 로그인 실패 횟수 카운팅 없음
// → 계정 잠금 정책 없음
// → 비정상 API 접근 패턴 감지 없음
```

**권고 구현**:

```java
// 로그인 실패 카운팅 + 계정 잠금
@Service
public class BruteForceProtectionService {

    private static final int MAX_ATTEMPTS = 5;
    private static final Duration LOCK_DURATION = Duration.ofMinutes(30);

    public void recordFailedLogin(String username, String ip) {
        String userKey = "login:fail:user:" + username;
        String ipKey   = "login:fail:ip:" + ip;

        Long userFailCount = redisTemplate.opsForValue().increment(userKey);
        Long ipFailCount   = redisTemplate.opsForValue().increment(ipKey);

        redisTemplate.expire(userKey, LOCK_DURATION);
        redisTemplate.expire(ipKey, LOCK_DURATION);

        if (userFailCount >= MAX_ATTEMPTS) {
            accountService.lock(username, "BRUTE_FORCE_DETECTED");
            auditService.record("ACCOUNT_LOCKED_BRUTE_FORCE", username, ip);
            alertService.sendSecurityAlert("계정 잠금: " + username + " from " + ip);
        }

        if (ipFailCount >= MAX_ATTEMPTS * 3) {
            firewallService.blockIp(ip, Duration.ofHours(1));
            auditService.record("IP_BLOCKED", ip, "EXCESSIVE_FAILURES");
        }
    }
}

// 비정상 API 접근 패턴 감지 (Gateway 필터)
@Component
public class AnomalyDetectionFilter implements GlobalFilter {
    @Override
    public Mono<Void> filter(ServerWebExchange exchange, GatewayFilterChain chain) {
        String uri = exchange.getRequest().getURI().getPath();
        String ip  = getClientIp(exchange);
        String user = extractUser(exchange);

        // ❶ 인증 없는 내부 API 직접 접근 시도
        if (uri.startsWith("/internal/") && !isInternalNetwork(ip)) {
            auditService.record("UNAUTHORIZED_INTERNAL_ACCESS", user, uri);
            return Mono.error(new ForbiddenException("내부 API 직접 접근 차단"));
        }

        // ❷ 비정상적 요청 속도 (초당 100회 이상)
        String rateKey = "req:rate:" + user;
        Long reqCount = redisTemplate.opsForValue().increment(rateKey);
        if (reqCount == 1) redisTemplate.expire(rateKey, Duration.ofSeconds(1));
        if (reqCount != null && reqCount > 100) {
            auditService.record("RATE_LIMIT_EXCEEDED", user, uri);
            // 429 Too Many Requests
        }

        return chain.filter(exchange);
    }
}
```

