// 1. 감사 이벤트 엔티티 (Append-Only, 수정/삭제 불가)
@Entity
@Table(name = "audit_trail",
       indexes = {
           @Index(name = "idx_audit_member_time",  columnList = "memberId, eventTime"),
           @Index(name = "idx_audit_order",        columnList = "orderId"),
           @Index(name = "idx_audit_investor",     columnList = "investorCi, eventTime"),
           @Index(name = "idx_audit_symbol_time",  columnList = "symbol, eventTime")
       })
@Immutable  // Hibernate: UPDATE/DELETE 차단
public class AuditTrail {

    @Id
    @Column(columnDefinition = "CHAR(36)")
    private String trailId = UUID.randomUUID().toString();

    // ── 이벤트 분류 ─────────────────────────────
    @Column(nullable = false, length = 40)
    private String eventType;          // ORDER_RECEIVED | ORDER_MATCHED | ORDER_CANCELLED...

    // ── 주체 정보 ────────────────────────────────
    @Column(nullable = false, length = 10)
    private String memberId;           // KRX 회원사 코드 (예: 00180)

    @Column(nullable = false, length = 20)
    private String accountNo;          // 계좌번호 (AES-256 암호화 저장)

    @Column(nullable = false, length = 88)
    private String investorCi;         // 투자자 CI (Connecting Information, 해시)

    // ── 주문/체결 상세 ──────────────────────────
    @Column(nullable = false, length = 36)
    private String orderId;            // 거래소 주문 번호 (UUID)

    @Column(length = 64)
    private String clOrdId;            // FIX Tag 11: 회원사 자체 주문 번호

    @Column(length = 64)
    private String execId;             // FIX Tag 17: 체결 확인 번호

    @Column(length = 20)
    private String symbol;             // 종목코드

    @Column(columnDefinition = "TEXT")
    private String payload;            // 전체 파라미터 JSON (암호화 옵션)

    // ── 시각 (나노초 정밀도) ─────────────────────
    @Column(nullable = false)
    private Instant eventTime;         // UTC 나노초

    @Column(nullable = false)
    private Instant receivedAt;        // 게이트웨이 수신 시각 (MiFID II RTS 25)

    // ── 접속 정보 ────────────────────────────────
    @Column(length = 45)
    private String sourceIp;           // IPv4/IPv6

    @Column(length = 10)
    private String channelCode;        // HTS | MTS | API | FIX

    @Column(length = 40)
    private String userAgent;          // 클라이언트 앱 버전

    // ── 무결성 보장 (해시체인) ───────────────────
    @Column(nullable = false, length = 64)
    private String prevTrailHash;      // 이전 감사 레코드의 해시

    @Column(nullable = false, length = 64)
    private String trailHash;          // SHA-256(prevHash + payload + eventTime + trailId)

    @Column(nullable = false, length = 30)
    private String serverId;           // 처리 서버 식별자
}

// 2. 감사 서비스 — 비동기 기록 (주문 경로 지연 최소화)
@Service
public class AuditTrailService {

    private final AuditTrailRepository auditRepo;
    private final String serverId = System.getenv("SERVER_ID");

    @Async("auditExecutor")
    public CompletableFuture<Void> record(AuditEvent event) {
        String prevHash = auditRepo.getLastHash(event.getMemberId())
                .orElse("GENESIS");

        String content = prevHash + event.getPayload()
                + event.getEventTime().toString() + event.getTrailId();
        String trailHash = DigestUtils.sha256Hex(content);

        AuditTrail trail = AuditTrail.builder()
                .trailId(UUID.randomUUID().toString())
                .eventType(event.getType().name())
                .memberId(event.getMemberId())
                .accountNo(aes256Encrypt(event.getAccountNo()))  // 암호화
                .investorCi(sha256Hash(event.getCi()))           // 해시
                .orderId(event.getOrderId())
                .payload(event.getPayload())
                .eventTime(Instant.now())
                .receivedAt(event.getReceivedAt())
                .sourceIp(event.getSourceIp())
                .channelCode(event.getChannelCode())
                .prevTrailHash(prevHash)
                .trailHash(trailHash)
                .serverId(serverId)
                .build();

        auditRepo.save(trail);
        return CompletableFuture.completedFuture(null);
    }
}

// 3. 5년 데이터 보존 전략
// MySQL: 연도별 파티셔닝 → Glacier(Cold Storage) 이관
// application.yml:
// audit:
//   retention-years: 5
//   archive-target: s3://krx-audit-archive/
//   encryption: AES-256-GCM
```

