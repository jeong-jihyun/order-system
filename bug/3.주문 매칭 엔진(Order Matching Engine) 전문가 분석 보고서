// OrderBook 내부에서 ReentrantReadWriteLock으로 통일
public class OrderBook {
    private final ReentrantReadWriteLock lock = new ReentrantReadWriteLock();
    private final Lock readLock  = lock.readLock();
    private final Lock writeLock = lock.writeLock();

    public void addOrder(OrderBookEntry entry) {
        writeLock.lock();
        try { /* ... */ }
        finally { writeLock.unlock(); }
    }

    public boolean cancelOrder(Long orderId, OrderSide side, BigDecimal price) {
        writeLock.lock();  // 매칭과 동일한 lock 사용
        try { /* ... */ }
        finally { writeLock.unlock(); }
    }

    public OrderBookSnapshot getSnapshot(int depth) {
        readLock.lock();   // 읽기는 병렬 허용
        try { /* ... */ }
        finally { readLock.unlock(); }
    }
}

// MatchingEngine.match()도 synchronized 제거 → OrderBook 내부 lock으로 통일
public List<ExecutionResult> match(OrderBook orderBook, OrderBookEntry newOrder) {
    // synchronized(orderBook) 제거 → OrderBook이 자체 lock 관리
    return orderBook.matchOrder(newOrder); // OrderBook이 직접 매칭 수행
}
