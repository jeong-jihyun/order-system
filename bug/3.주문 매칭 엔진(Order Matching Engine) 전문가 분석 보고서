```java
// Incremental Update 방식으로 전환 (Snapshot + Delta)
// 1. 체결 후 변경된 가격 레벨만 이벤트 발행
public class OrderBookDelta {
    private final String symbol;
    private final long   sequenceNumber;  // 단조 증가 (클라이언트 순서 보장)
    private final List<PriceLevelChange> bidsChanged;
    private final List<PriceLevelChange> asksChanged;
    private final Instant timestamp;
}

// 2. MatchingEngine 완료 후 delta 계산 및 발행
public List<ExecutionResult> match(OrderBook orderBook, OrderBookEntry newOrder) {
    OrderBookState before = orderBook.snapshot(); // 매칭 전 상태
    List<ExecutionResult> executions = doMatch(orderBook, newOrder);
    OrderBookState after  = orderBook.snapshot(); // 매칭 후 상태
    OrderBookDelta delta  = computeDelta(before, after);
    deltaPublisher.publish(delta);                // WebSocket으로 실시간 발행
    return executions;
}
```

