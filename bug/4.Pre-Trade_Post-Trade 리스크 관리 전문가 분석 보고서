```

**권고 구현**:
```java
// Append-Only 감사 이벤트 엔티티
@Entity
@Table(name = "audit_events")
@Immutable  // 수정/삭제 절대 불가
public class AuditEvent {

    @Id
    private UUID eventId = UUID.randomUUID();

    private String   eventType;       // ORDER_RECEIVED, MATCHED 등
    private String   memberId;        // 회원사 ID
    private Long     orderId;
    private String   symbol;
    private Instant  eventTime;       // 나노초 UTC
    private String   sourceIp;        // 클라이언트 IP
    private String   sessionId;       // 세션 ID
    private String   payload;         // 전체 파라미터 JSON

    // 해시체인 (이전 이벤트와 연결 → 위변조 감지)
    private String   prevEventHash;
    private String   eventHash;       // SHA-256(prevHash + payload + eventTime)

    private String   processedBy;     // 처리 서버 ID
}

// 감사 서비스
@Service
public class AuditService {

    @Async("auditExecutor")  // 별도 스레드풀 — 주문 경로 지연 최소화
    public void record(String eventType, String memberId,
                        Long orderId, String payload) {
        String prevHash = getLastEventHash(memberId);
        String content  = prevHash + payload + Instant.now().toString();
        String hash     = sha256(content);

        auditEventRepository.save(AuditEvent.builder()
            .eventType(eventType)
            .memberId(memberId)
            .orderId(orderId)
            .eventTime(Instant.now())
            .sourceIp(RequestContextHolder.getIp())
            .payload(payload)
            .prevEventHash(prevHash)
            .eventHash(hash)
            .build());
    }
}
```

