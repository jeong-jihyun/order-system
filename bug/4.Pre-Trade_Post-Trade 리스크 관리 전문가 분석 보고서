**권고 구현**:
```java
// OrderKafkaConsumer에 Halt 체크 추가
@KafkaListener(topics = "order-events", ...)
public void consume(String message) {
    String symbol = extractSymbol(message);

    // ❶ 종목 거래 정지 여부 확인
    if (haltService.isHalted(symbol)) {
        // Halt 중 주문은 Queue에 보관 (재개 시 일괄 처리)
        haltOrderQueue.enqueue(symbol, message);
        orderStatusService.updateStatus(orderId, OrderStatus.SUSPENDED,
            "TRADING_HALT: " + symbol);
        auditLog.warn(AuditEvent.ORDER_SUSPENDED_HALT,
            "symbol={}, orderId={}", symbol, orderId);
        return;
    }

    // ❷ 정상 경로
    executionService.processOrder(...);
}

// 거래 재개 시
@EventListener
public void onHaltLifted(HaltLiftedEvent event) {
    List<String> queuedOrders = haltOrderQueue.dequeue(event.getSymbol());
    queuedOrders.forEach(msg ->
        executionService.processOrder(/* ... */));
    auditLog.info(AuditEvent.TRADING_RESUMED,
        "symbol={}, queuedOrders={}", event.getSymbol(), queuedOrders.size());
}
```

